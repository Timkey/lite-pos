# Ensure shell scripts always use LF line endings (Unix style)
*.sh text eol=lf

# Git hooks should always use LF
.git/hooks/* text eol=lf

# Web files use LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Windows-specific files can keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.webp binary
